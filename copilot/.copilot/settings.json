{
  // Default model and effort
  "model": "claude-opus-4.6",
  "effortLevel": "high",

  // Logging — keep verbose for debugging; set to "default" to reduce noise
  "logLevel": "all",

  // Skills marketplace sources
  "extraKnownMarketplaces": {
    "azure-skills": {
      "source": {
        "source": "github",
        "repo": "microsoft/azure-skills"
      }
    }
  },

  // Enabled plugins
  "enabledPlugins": {
    "azure@azure-skills": true
  },

  // Custom status line script
  "statusline": {
    "script": "~/.copilot/copilot-statusline.js"
  },

  // Audio notification when attention is needed (analogous to opencode tui.json sound)
  "beep": true,

  // Terminal theme follows system dark/light
  "theme": "auto",

  // Auto-update from stable channel
  "autoUpdate": true,
  "autoUpdatesChannel": "stable",

  // Suppress the startup banner/animation entirely
  "banner": "never",

  // Allow the agent to ask clarifying questions
  "askUser": true,

  // Emit OSC 9;4 progress indicators (Ghostty, iTerm2, Windows Terminal)
  "terminalProgress": true,

  // Update terminal tab title with current intent
  "updateTerminalTitle": true,

  // Git co-author attribution for agent commits
  "includeCoAuthoredBy": true,

  // Respect .gitignore in file picker
  "respectGitignore": true,

  // Prevent sleep while agent is actively working
  "keepAlive": "busy",

  // Collapse large pastes
  "compactPaste": true,

  // Render markdown in output
  "renderMarkdown": true,

  // Status line items
  "footer": {
    "showModelEffort": true,
    "showDirectory": true,
    "showBranch": true,
    "showContextWindow": true,
    "showQuota": true,
    "showAgent": true
  }
}
