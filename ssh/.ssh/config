# Host-specific overrides (create files in ~/.ssh/config.d/)
Include ~/.ssh/config.d/*

Host *
    # Keep connections alive through idle periods and detect broken links
    # Aggressive keep-alive: detects dead connections within ~30s
    ServerAliveInterval 10
    ServerAliveCountMax 3
    TCPKeepAlive yes

    # Compress the SSH channel (helps on slow/mobile links)
    Compression yes

    # Reuse connections for faster subsequent sessions
    ControlMaster auto
    ControlPath ~/.ssh/sockets/%r@%h-%p
    ControlPersist 600

    # Tolerate brief network interruptions during connection setup
    ConnectionAttempts 3
    ConnectTimeout 30

    # Do not forward agent by default (enable per-host in config.d/)
    ForwardAgent no

    # Only offer keys explicitly configured per-host via IdentityFile
    IdentitiesOnly yes

    # Pass locale and terminal env vars so the remote shell behaves correctly
    # Note: server must have matching AcceptEnv in sshd_config
    SendEnv LANG LC_* COLORTERM TERM_PROGRAM

    # Request a PTY that preserves terminal features (bell, OSC sequences)
    RequestTTY auto

    # Visual host key verification
    VisualHostKey no

    # Hash hostnames in known_hosts to limit info leakage
    HashKnownHosts yes

    # Prefer modern key exchange and ciphers
    AddKeysToAgent yes
