# bash completion for mvn/mvnw
_mvn_completion() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local phases="clean initialize process-resources compile process-test-resources
        test-compile test package verify install deploy site
        pre-integration-test integration-test"
    local plugins="dependency:tree dependency:analyze dependency:resolve dependency:sources
        dependency:copy-dependencies dependency:purge-local-repository dependency:go-offline
        compiler:compile compiler:testCompile resources:resources resources:testResources
        surefire:test failsafe:integration-test failsafe:verify
        install:install-file deploy:deploy-file
        archetype:generate assembly:single
        exec:exec exec:java
        versions:display-dependency-updates versions:display-plugin-updates versions:set
        versions:use-latest-releases versions:use-latest-versions
        release:clean release:prepare release:perform release:rollback
        site:site site:deploy site:run
        javadoc:javadoc javadoc:jar javadoc:aggregate
        source:jar source:jar-no-fork source:test-jar
        help:active-profiles help:describe help:effective-pom help:effective-settings help:evaluate
        enforcer:enforce checkstyle:check checkstyle:checkstyle
        spring-boot:run spring-boot:repackage
        quarkus:dev quarkus:build quarkus:add-extension
        flyway:clean flyway:migrate flyway:info flyway:validate
        liquibase:update liquibase:rollback liquibase:status
        war:war ear:ear shade:shade
        fmt:format spotless:apply spotless:check
        wrapper:wrapper"
    local opts="-am --also-make -amd --also-make-dependents
        -B --batch-mode -C --strict-checksums -c --lax-checksums
        -D --define -e --errors -f --file
        -fae --fail-at-end -ff --fail-fast -fn --fail-never
        -h --help -l --log-file -N --non-recursive
        -nsu --no-snapshot-updates -o --offline
        -P --activate-profiles -pl --projects
        -q --quiet -rf --resume-from
        -s --settings -T --threads
        -U --update-snapshots -V --show-version -X --debug
        -DskipTests -DskipITs -Dmaven.test.skip=true"

    COMPREPLY=( $(compgen -W "$phases $plugins $opts" -- "$cur") )
}
complete -o default -F _mvn_completion mvn mvnw
